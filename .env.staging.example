# ═══════════════════════════════════════════════════════════════════════════════
# DeepSynaps Protocol Studio — Staging Environment Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env.staging and fill in real values. NEVER commit real secrets.
# See: docs/deployment/backend-staging-connect.md
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────────────
DEEPSYNAPS_APP_ENV=staging

# ── Frontend (set in Netlify, not in .env) ─────────────────────────────────────
VITE_API_BASE_URL=https://deepsynaps-studio.fly.dev
VITE_ENABLE_DEMO=0

# ── Database ───────────────────────────────────────────────────────────────────
DEEPSYNAPS_DATABASE_URL=postgresql://user:password@host:5432/deepsynaps_staging

# ── Auth & Security ───────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING
DEEPSYNAPS_SECRETS_KEY=CHANGE_ME_FERNET_KEY
WEARABLE_TOKEN_ENC_KEY=CHANGE_ME_32_CHAR_KEY

# ── CORS ───────────────────────────────────────────────────────────────────────
DEEPSYNAPS_CORS_ORIGINS=https://deepsynaps-studio-preview.netlify.app

# ── Redis / Celery ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://default:password@host:6379/0
CELERY_RESULT_BACKEND=
DEEPSYNAPS_LIMITER_REDIS_URI=

# ── AI / LLM Providers ────────────────────────────────────────────────────────
# At least one is recommended for copilot features.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GLM_API_KEY=

# ── ML Model Weights ──────────────────────────────────────────────────────────
BRAINAGE_WEIGHTS_PATH=
FOUNDATION_WEIGHTS_DIR=

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Evidence / MedRAG ──────────────────────────────────────────────────────────
# pgvector requires PostgreSQL with the pgvector extension enabled.
# When unset, MedRAG falls back to keyword-based retrieval.
EVIDENCE_DB_PATH=
