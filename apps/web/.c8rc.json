{
  "all": true,
  "include": [
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.ts",
    "src/**/*.jsx",
    "src/**/*.tsx"
  ],
  "exclude": [
    "**/*.test.js",
    "**/*.test.mjs",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.d.ts",
    "src/**/_gen_*.cjs",
    "src/**/__fixtures__/**",
    "src/**/__mocks__/**",
    "src/**/test-utils/**",
    "dist/**",
    "coverage/**",
    "node_modules/**",
    "playwright-report/**",
    "test-results/**",
    "tests/**"
  ],
  "reporter": ["text", "lcov", "html", "json-summary"],
  "reports-dir": "coverage",
  "check-coverage": false,
  "lines": 48,
  "branches": 65,
  "functions": 20,
  "statements": 48
}
