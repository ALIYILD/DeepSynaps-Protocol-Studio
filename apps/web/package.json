{
  "name": "@deepsynaps/web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint src/studio --max-warnings 0",
    "test": "npm run build && npm run test:unit",
    "test:deeptwin-neuroai-lab": "node --test src/deeptwin/neuroai-lab.test.js",
    "test:vitest": "vitest run",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "preview": "vite preview",
    "test:coverage": "c8 npm run test:unit",
    "test:coverage:html": "c8 --reporter=html --reporter=text npm run test:unit",
    "test:coverage:ci": "c8 --reporter=lcov --reporter=text-summary --reporter=json-summary --check-coverage npm run test:unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.44.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "c8": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^7.0.4",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@cornerstonejs/core": "^4.22.6",
    "@cornerstonejs/nifti-volume-loader": "^4.22.6",
    "@cornerstonejs/tools": "^4.22.6",
    "@deepsynaps/api-client": "*",
    "@icr/polyseg-wasm": "^0.4.0",
    "@radix-ui/react-context-menu": "^2.2.4",
    "plotly.js-dist-min": "^2.35.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "regl": "^2.1.0",
    "zustand": "^5.0.3"
  },
  "overrides": {
    "@icr/polyseg-wasm": "0.4.0"
  }
}
