// api-coverage.test.js — Deep coverage for apps/web/src/api.js
//
// Companion to api.test.js. Each test stubs globalThis.fetch, calls one
// api method, and asserts on the request shape (URL, method, body) plus,
// where useful, the parsed response. Error branches (4xx / 5xx / network
// error) are covered for representative methods.
//
// Run: node --test src/api-coverage.test.js

import { describe, it } from 'node:test';
import assert from 'node:assert';

// ── Minimal DOM / browser stubs (mirrors api.test.js) ──────────────────────
if (typeof globalThis.localStorage === 'undefined') {
  const _store = {};
  globalThis.localStorage = {
    getItem: (k) => Object.prototype.hasOwnProperty.call(_store, k) ? _store[k] : null,
    setItem: (k, v) => { _store[k] = String(v); },
    removeItem: (k) => { delete _store[k]; },
    clear: () => { Object.keys(_store).forEach(k => delete _store[k]); },
  };
}
if (typeof globalThis.URL === 'undefined') {
  const { URL } = await import('node:url');
  globalThis.URL = URL;
}
if (typeof globalThis.FormData === 'undefined') {
  class FormData {
    constructor() { this._data = []; }
    append(k, v) { this._data.push([k, v]); }
    get(k) { const e = this._data.find(([key]) => key === k); return e ? e[1] : null; }
  }
  globalThis.FormData = FormData;
}
if (typeof globalThis.Blob === 'undefined') {
  globalThis.Blob = class Blob { constructor(parts = []) { this._parts = parts; } };
}

// Import after stubs
const { api, API_BASE } = await import('./api.js');

// ── Helpers ────────────────────────────────────────────────────────────────
function _makeFakeResponse(body, status = 200, headers = { 'content-type': 'application/json' }) {
  const bodyStr = body === null
    ? 'null'
    : (typeof body === 'string' ? body : JSON.stringify(body));
  return {
    status,
    ok: status >= 200 && status < 300,
    headers: { get: (k) => headers[String(k).toLowerCase()] ?? null },
    json: () => Promise.resolve(JSON.parse(bodyStr)),
    text: () => Promise.resolve(bodyStr),
    blob: () => Promise.resolve({ _data: bodyStr }),
    clone() { return _makeFakeResponse(body, status, headers); },
  };
}

function stubFetch(responseBody, status = 200, headers) {
  const original = globalThis.fetch;
  let captured = null;
  globalThis.fetch = (url, init) => {
    captured = {
      url: String(url),
      method: init?.method || 'GET',
      body: init?.body,
      headers: init?.headers,
    };
    return Promise.resolve(_makeFakeResponse(responseBody, status, headers));
  };
  return {
    getCaptured: () => captured,
    restore: () => { globalThis.fetch = original; },
  };
}

function stubFetchNetworkError(message = 'getaddrinfo ENOTFOUND') {
  const original = globalThis.fetch;
  globalThis.fetch = () => Promise.reject(new TypeError(message));
  return { restore: () => { globalThis.fetch = original; } };
}

async function expectThrows(promise) {
  try { await promise; } catch (e) { return e; }
  throw new Error('Expected promise to reject');
}

// ── 1. Auth — additional methods ───────────────────────────────────────────
describe('auth — extra methods', () => {
  it('api.logout POSTs to /api/v1/auth/logout with refresh token field', async () => {
    api.setRefreshToken('rfh-1');
    const stub = stubFetch({ ok: true });
    try {
      await api.logout();
      const c = stub.getCaptured();
      assert.ok(c.url.endsWith('/api/v1/auth/logout'));
      assert.strictEqual(c.method, 'POST');
      const body = JSON.parse(c.body);
      assert.strictEqual(body.refresh_token, 'rfh-1');
    } finally { stub.restore(); api.clearRefreshToken(); }
  });

  it('api.logout sends null refresh_token if none stored', async () => {
    api.clearRefreshToken();
    const stub = stubFetch({ ok: true });
    try {
      await api.logout();
      const body = JSON.parse(stub.getCaptured().body);
      assert.strictEqual(body.refresh_token, null);
    } finally { stub.restore(); }
  });

  it('api.activatePatient POSTs to /api/v1/auth/activate-patient', async () => {
    const stub = stubFetch({ ok: true });
    try {
      await api.activatePatient('CODE123', 'p@t.com', 'Pat', 'pw');
      const c = stub.getCaptured();
      assert.ok(c.url.endsWith('/api/v1/auth/activate-patient'));
      assert.strictEqual(c.method, 'POST');
      const body = JSON.parse(c.body);
      assert.strictEqual(body.invite_code, 'CODE123');
      assert.strictEqual(body.email, 'p@t.com');
    } finally { stub.restore(); }
  });

  it('api.refresh POSTs to /api/v1/auth/refresh with refresh_token', async () => {
    const stub = stubFetch({ access_token: 'newtok' });
    try {
      await api.refresh('rfh-zzz');
      const c = stub.getCaptured();
      assert.ok(c.url.endsWith('/api/v1/auth/refresh'));
      assert.strictEqual(JSON.parse(c.body).refresh_token, 'rfh-zzz');
    } finally { stub.restore(); }
  });

  it('api.resetPassword POSTs token + new_password', async () => {
    const stub = stubFetch({ ok: true });
    try {
      await api.resetPassword('reset-tok', 'NewPass!');
      const c = stub.getCaptured();
      assert.ok(c.url.endsWith('/api/v1/auth/reset-password'));
      const body = JSON.parse(c.body);
      assert.strictEqual(body.token, 'reset-tok');
      assert.strictEqual(body.new_password, 'NewPass!');
    } finally { stub.restore(); }
  });

  it('api.login stores returned refresh_token', async () => {
    api.clearRefreshToken();
    const stub = stubFetch({ access_token: 'a', refresh_token: 'fresh-r' });
    try {
      await api.login('u@v.com', 'pw');
      assert.strictEqual(api.getRefreshToken(), 'fresh-r');
    } finally { stub.restore(); api.clearRefreshToken(); }
  });
});

