// ── 38. Error handling ─────────────────────────────────────────────────────
describe('error handling', () => {
  it('apiFetch throws on 500 with API error message', async () => {
    const stub = stubFetch({ detail: 'boom' }, 500);
    try {
      const e = await expectThrows(api.getPatient('pt-1'));
      assert.strictEqual(e.status, 500);
      assert.ok(/API error 500|boom/.test(e.message));
    } finally { stub.restore(); }
  });

  it('apiFetch throws on 404 with API error', async () => {
    const stub = stubFetch({ detail: 'not found' }, 404);
    try {
      const e = await expectThrows(api.getPatient('pt-missing'));
      assert.strictEqual(e.status, 404);
    } finally { stub.restore(); }
  });

  it('apiFetch attaches error code and details on JSON error body', async () => {
    const stub = stubFetch({ message: 'invalid', code: 'INVALID', details: { field: 'x' } }, 400);
    try {
      const e = await expectThrows(api.getPatient('pt-1'));
      assert.strictEqual(e.code, 'INVALID');
      assert.deepStrictEqual(e.details, { field: 'x' });
    } finally { stub.restore(); }
  });

  it('apiFetch returns null on 204 No Content', async () => {
    const stub = stubFetch(null, 204);
    try {
      const out = await api.deletePatient('pt-1');
      assert.strictEqual(out, null);
    } finally { stub.restore(); }
  });

  it('apiFetch propagates network errors as Error{status:0}', async () => {
    const stub = stubFetchNetworkError('disconnect');
    try {
      const e = await expectThrows(api.getPatient('pt-1'));
      assert.strictEqual(e.status, 0);
      assert.strictEqual(e.message, 'Network error');
    } finally { stub.restore(); }
  });

  it('apiFetchWithRetry surfaces 4xx without retry', async () => {
    const stub = stubFetch({ detail: 'no' }, 422);
    try {
      const e = await expectThrows(api.listPatients());
      assert.strictEqual(e.status, 422);
    } finally { stub.restore(); }
  });
});

// ── 39. Headers + auth ─────────────────────────────────────────────────────
describe('request headers', () => {
  it('attaches Authorization when token is set', async () => {
    api.setToken('jwt-xxx');
    const stub = stubFetch({});
    try {
      await api.me();
      const auth = stub.getCaptured().headers.Authorization || stub.getCaptured().headers.authorization;
      assert.strictEqual(auth, 'Bearer jwt-xxx');
    } finally { stub.restore(); api.clearToken(); }
  });

  it('omits Authorization when no token', async () => {
    api.clearToken();
    const stub = stubFetch({});
    try {
      await api.me();
      const auth = stub.getCaptured().headers.Authorization || stub.getCaptured().headers.authorization;
      assert.ok(auth == null);
    } finally { stub.restore(); }
  });

  it('sends Content-Type: application/json by default for JSON POST', async () => {
    const stub = stubFetch({});
    try {
      await api.createPatient({ name: 'X' });
      const ct = stub.getCaptured().headers['Content-Type'];
      assert.strictEqual(ct, 'application/json');
    } finally { stub.restore(); }
  });

  it('does not send Content-Type when body is FormData', async () => {
    const stub = stubFetch({});
    try {
      const fd = new globalThis.FormData();
      fd.append('file', 'dummy');
      await api.uploadQEEGRecording(fd);
      const ct = stub.getCaptured().headers['Content-Type']
        ?? stub.getCaptured().headers['content-type'];
      assert.strictEqual(ct, undefined);
    } finally { stub.restore(); }
  });
});

// ── 40. Audio analyze ──────────────────────────────────────────────────────
describe('audio analyze', () => {
  it('api.audioAnalyzeRecording POSTs with session_id', async () => {
    const stub = stubFetch({});
