// ── 14. Chat ───────────────────────────────────────────────────────────────
describe('chat', () => {
  it('api.chatAgent POSTs default provider=anthropic', async () => {
    const stub = stubFetch({ reply: 'hi' });
    try {
      await api.chatAgent([{ role: 'user', content: 'q' }]);
      const body = JSON.parse(stub.getCaptured().body);
      assert.strictEqual(body.provider, 'anthropic');
    } finally { stub.restore(); }
  });

  it('api.chatAgent supports openai_key', async () => {
    const stub = stubFetch({ reply: '' });
    try {
      await api.chatAgent([], 'openai', 'sk-xyz');
