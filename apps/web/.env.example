# ── Frontend Environment Variables ────────────────────────────────────────────
# Copy to .env and customize for your environment.
# NEVER commit .env files with real secrets.

# ── Demo Mode ────────────────────────────────────────────────────────────────
# Set to "1" to enable demo mode UI (global banner, demo labels, etc.)
# Production builds should leave this unset or "0".
VITE_ENABLE_DEMO=0

# Label shown in the demo mode banner (default: "DEMO BUILD")
VITE_DEMO_MODE_LABEL="DEMO BUILD"

# Show the non-PHI / synthetic data banner (default: true)
# Set to "0" to hide the banner even in demo mode.
VITE_DEMO_NON_PHI_BANNER=1

# ── Legacy Demo Flag (deprecated, use VITE_ENABLE_DEMO) ───────────────────────
# VITE_DEMO_MODE=true
