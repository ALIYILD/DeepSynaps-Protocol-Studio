# ============================================================
# DeepSynaps Protocol Studio — API Environment Variables
# ============================================================
# This file lives alongside the API package. The canonical
# project-level .env.example is at the repository root.
# All variable names match apps/api/app/settings.py exactly.
# ============================================================

# ============================================================
# PRODUCTION QUICK-START (Fly.io)
# Set these as Fly secrets: fly secrets set KEY=value
# ============================================================
# DEEPSYNAPS_APP_ENV=production
# DEEPSYNAPS_DATABASE_URL=sqlite:////data/deepsynaps_protocol_studio.db
# DEEPSYNAPS_CORS_ORIGINS=https://deepsynaps-web.fly.dev,https://deepsynaps-studio.fly.dev,https://your-custom-domain.com
# JWT_SECRET_KEY=$(openssl rand -hex 32)
# DEEPSYNAPS_SECRETS_KEY=$(python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# APP_URL=https://deepsynaps-studio.fly.dev
# MEDIA_STORAGE_ROOT=/data/media_uploads
# ============================================================

# Application
DEEPSYNAPS_APP_ENV=development
DEEPSYNAPS_LOG_LEVEL=INFO
# DEEPSYNAPS_API_TITLE=DeepSynaps Protocol Studio API
# DEEPSYNAPS_API_VERSION=0.1.0

# Server
DEEPSYNAPS_API_HOST=127.0.0.1
DEEPSYNAPS_API_PORT=8000
DEEPSYNAPS_REQUEST_TIMEOUT_SECONDS=30

# Database
# Development (SQLite):
DEEPSYNAPS_DATABASE_URL=sqlite:///./deepsynaps_protocol_studio.db
# Production (PostgreSQL):
# DEEPSYNAPS_DATABASE_URL=postgresql://user:password@host:5432/deepsynaps_prod

# CORS (comma-separated origins; defaults to localhost Vite ports when unset)
DEEPSYNAPS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production: DEEPSYNAPS_CORS_ORIGINS=https://deepsynaps-web.fly.dev,https://deepsynaps-studio.fly.dev

# Data paths (optional — defaults resolve relative to repo root)
# DEEPSYNAPS_CLINICAL_DATA_ROOT=/app/data/imports/clinical-database
# DEEPSYNAPS_CLINICAL_SNAPSHOT_ROOT=/app/data/snapshots/clinical-database
# DEEPSYNAPS_DATABASE_BACKUP_ROOT=/app/data/backups
# Canonical neuromodulation research bundle root for the enriched CSV/XLSX pipeline
# DEEPSYNAPS_NEUROMODULATION_RESEARCH_BUNDLE_ROOT=/absolute/path/to/neuromodulation_research_bundle_2026-04-22

# JWT Authentication
# REQUIRED in production/staging — the server will refuse to start if this is
# the placeholder value or unset.  Generate a secure value:
#   openssl rand -hex 32
# Then set it as a secret (Fly.io):
#   fly secrets set JWT_SECRET_KEY=$(openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Settings/API secret encryption
# REQUIRED in production/staging for stable 2FA/TOTP secret persistence.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DEEPSYNAPS_SECRETS_KEY=REPLACE_ME_WITH_FERNET_KEY

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_RESIDENT=price_REPLACE_ME
STRIPE_PRICE_CLINICIAN_PRO=price_REPLACE_ME
STRIPE_PRICE_CLINIC_TEAM=price_REPLACE_ME
# Current pricing page plan IDs (fall back to legacy IDs above if unset)
STRIPE_PRICE_CLINIC_STARTER=
STRIPE_PRICE_CLINIC_PRO=

# Telegram
# TELEGRAM_WEBHOOK_SECRET must match the secret_token you pass to setWebhook.
# The server validates X-Telegram-Bot-Api-Secret-Token on every webhook POST.
# Generate with: openssl rand -hex 24
TELEGRAM_BOT_TOKEN=1234567890:REPLACE_ME
TELEGRAM_WEBHOOK_SECRET=REPLACE_ME

# Sentry (leave blank to disable)
SENTRY_DSN=https://REPLACE_ME@oXXXXXX.ingest.sentry.io/REPLACE_ME

# Anthropic (AI Generation)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# OpenAI (optional — used for Whisper transcription and fallback LLM)
OPENAI_API_KEY=sk-REPLACE_ME

# App public URL (used for Stripe redirect URLs)
APP_URL=http://localhost:5173

# Frontend origin (alias used by some deployment guides; same as APP_URL for single-host deploys)
FRONTEND_URL=http://localhost:5173

# Media storage
MEDIA_STORAGE_BACKEND=local
MEDIA_STORAGE_ROOT=./media_uploads
MEDIA_MAX_UPLOAD_BYTES=52428800
MEDIA_SIGNED_URL_TTL_SECONDS=3600

# Wearable token encryption (Fernet key — required before enabling real OAuth device connections)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If absent, OAuth tokens are stored as plaintext and a WARNING is logged on every write.
WEARABLE_TOKEN_ENC_KEY=REPLACE_ME_WITH_FERNET_KEY
