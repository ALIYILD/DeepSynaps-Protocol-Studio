# Application
DEEPSYNAPS_APP_ENV=development
DEEPSYNAPS_LOG_LEVEL=INFO

# Server
DEEPSYNAPS_API_HOST=127.0.0.1
DEEPSYNAPS_API_PORT=8000

# Database
DEEPSYNAPS_DATABASE_URL=sqlite:///./deepsynaps_protocol_studio.db
# For production: postgresql://user:password@host:5432/deepsynaps

# CORS (comma-separated origins)
DEEPSYNAPS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# For production: https://deepsynaps-studio.fly.dev

# Data paths (optional - defaults are relative to app directory)
# DEEPSYNAPS_CLINICAL_DATA_ROOT=/app/data/imports/clinical-database
# DEEPSYNAPS_CLINICAL_SNAPSHOT_ROOT=/app/data/snapshots/clinical-database
# DEEPSYNAPS_DATABASE_BACKUP_ROOT=/app/data/backups

# Future: Payment (Stripe)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLIC_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Future: Error tracking
# SENTRY_DSN=https://...@sentry.io/...

# Future: Auth
# JWT_SECRET_KEY=...
# JWT_ALGORITHM=HS256
# JWT_EXPIRY_MINUTES=60
