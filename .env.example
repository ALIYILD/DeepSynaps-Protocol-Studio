# ============================================================
# DeepSynaps Protocol Studio — Environment Variables
# ============================================================
# Copy this file to .env (never commit .env) and fill in real
# values before running the application locally or in production.
#
# Variable names are read directly by apps/api/app/settings.py
# via load_settings() → os.getenv(...).
# ============================================================


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Runtime environment. Controls security headers, Sentry sampling, etc.
# Allowed: development | test | staging | production
DEEPSYNAPS_APP_ENV=development

# Log verbosity.
# Allowed: DEBUG | INFO | WARNING | ERROR
DEEPSYNAPS_LOG_LEVEL=INFO

# Human-readable API title shown in OpenAPI docs (optional override).
# DEEPSYNAPS_API_TITLE=DeepSynaps Protocol Studio API

# Semantic version shown in OpenAPI docs (optional override).
# DEEPSYNAPS_API_VERSION=0.1.0


# ------------------------------------------------------------
# Server
# ------------------------------------------------------------

# Interface the uvicorn server binds to.
# Use 0.0.0.0 inside Docker; 127.0.0.1 for local-only dev.
DEEPSYNAPS_API_HOST=127.0.0.1

# Port uvicorn listens on (Docker exposes 8080; override if needed).
DEEPSYNAPS_API_PORT=8000

# Upstream request timeout in seconds.
DEEPSYNAPS_REQUEST_TIMEOUT_SECONDS=30


# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# SQLAlchemy connection URL.
#
# Development (SQLite — zero setup):
DEEPSYNAPS_DATABASE_URL=sqlite:///./deepsynaps_protocol_studio.db

# Production (PostgreSQL — recommended):
# DEEPSYNAPS_DATABASE_URL=postgresql://deepsynaps_user:CHANGE_ME@db-host:5432/deepsynaps_prod
#
# Fly.io Postgres example:
# DEEPSYNAPS_DATABASE_URL=postgresql://deepsynaps_user:CHANGE_ME@deepsynaps-db.flycast:5432/deepsynaps_prod?sslmode=require


# ------------------------------------------------------------
# CORS (comma-separated list of allowed origins)
# ------------------------------------------------------------

# Development: Vite dev server ports 5173-5177 are allowed by default
# when this variable is unset. Set it explicitly to restrict origins.
DEEPSYNAPS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production example (replace with your actual frontend URL):
# DEEPSYNAPS_CORS_ORIGINS=https://deepsynaps-studio.fly.dev


# ------------------------------------------------------------
# Data Paths (optional — defaults resolve relative to repo root)
# ------------------------------------------------------------

# Absolute path to the clinical database imports directory.
# DEEPSYNAPS_CLINICAL_DATA_ROOT=/app/data/imports/clinical-database

# Absolute path to the clinical database snapshots directory.
# DEEPSYNAPS_CLINICAL_SNAPSHOT_ROOT=/app/data/snapshots/clinical-database

# Absolute path to the database backup directory.
# DEEPSYNAPS_DATABASE_BACKUP_ROOT=/app/data/backups


# ------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------

# REQUIRED IN PRODUCTION. Generate with:
#   openssl rand -hex 32
JWT_SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-use-openssl-rand-hex-32

# Signing algorithm. HS256 is the default and recommended option.
JWT_ALGORITHM=HS256

# How long access tokens remain valid (minutes).
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# How long refresh tokens remain valid (days).
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30


# ------------------------------------------------------------
# Stripe (Payments)
# ------------------------------------------------------------
# Obtain keys from https://dashboard.stripe.com/apikeys
# Test keys start with sk_test_ / pk_test_
# Live keys start with sk_live_ / pk_live_

# Server-side secret key — never expose to the frontend.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Client-side publishable key — safe to expose to the browser.
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Webhook signing secret — generated when you register the webhook endpoint
# in the Stripe dashboard (Developers → Webhooks → Add endpoint).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe Price IDs — created in the Stripe dashboard under Products.
# Required for subscription checkout to function.
STRIPE_PRICE_RESIDENT=price_REPLACE_ME
STRIPE_PRICE_CLINICIAN_PRO=price_REPLACE_ME
STRIPE_PRICE_CLINIC_TEAM=price_REPLACE_ME


# ------------------------------------------------------------
# Telegram
# ------------------------------------------------------------
# Obtain a bot token from @BotFather on Telegram.

TELEGRAM_BOT_TOKEN=1234567890:REPLACE_ME_WITH_BOT_TOKEN

# Optional secret used to validate incoming webhook payloads from Telegram.
TELEGRAM_WEBHOOK_SECRET=REPLACE_ME_WITH_WEBHOOK_SECRET


# ------------------------------------------------------------
# Sentry (Error Tracking)
# ------------------------------------------------------------
# Obtain your DSN from https://sentry.io → Settings → Projects → Client Keys.
# Leave blank to disable Sentry entirely.
SENTRY_DSN=https://REPLACE_ME@oXXXXXX.ingest.sentry.io/REPLACE_ME


# ------------------------------------------------------------
# Anthropic (AI Generation)
# ------------------------------------------------------------
# Obtain from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME


# ------------------------------------------------------------
# OpenAI (Whisper transcription + optional LLM fallback)
# ------------------------------------------------------------
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME


# ------------------------------------------------------------
# Media uploads
# ------------------------------------------------------------

MEDIA_STORAGE_BACKEND=local
MEDIA_STORAGE_ROOT=./media_uploads
MEDIA_MAX_UPLOAD_BYTES=52428800
MEDIA_SIGNED_URL_TTL_SECONDS=3600

# Transcription (OpenAI Whisper)
WHISPER_PROVIDER=openai
# OPENAI_API_KEY already set above — used for Whisper transcription


# ------------------------------------------------------------
# Application URL
# ------------------------------------------------------------
# The public-facing frontend URL. Used by Stripe for success/cancel
# redirect URLs after checkout.
APP_URL=http://localhost:5173

# Production example:
# APP_URL=https://deepsynaps-studio.fly.dev

# Frontend URL — alias for APP_URL used in CORS allow-list documentation.
# Set DEEPSYNAPS_CORS_ORIGINS (above) to restrict actual allowed origins.
FRONTEND_URL=http://localhost:5173


# ------------------------------------------------------------
# Wearable token encryption
# ------------------------------------------------------------
# Fernet key — required before enabling real OAuth device connections.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If absent, OAuth tokens are stored as plaintext and a WARNING is logged.
WEARABLE_TOKEN_ENC_KEY=REPLACE_ME_WITH_FERNET_KEY
