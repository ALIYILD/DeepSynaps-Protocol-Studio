# DeepSynaps Protocol Studio — Environment Configuration
# Copy to .env and fill in your values.

# ── App Environment ─────────────────────────────────────────────
# Options: development | test | staging | production
DEEPSYNAPS_APP_ENV=development

# ── Database ────────────────────────────────────────────────────
# SQLite (default for dev/test): set DEEPSYNAPS_DB to file path
# PostgreSQL (required for production): set DATABASE_URL
DATABASE_URL=
DEEPSYNAPS_DB=deepsynaps.db

# ── PostgreSQL Connection Pooling ──────────────────────────────
# Only used when DATABASE_URL is set (PostgreSQL mode)
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_RECYCLE=3600
POSTGRES_POOL_PRE_PING=true
POSTGRES_SSLMODE=prefer

# ── Demo Mode ──────────────────────────────────────────────────
DEEPSYNAPS_DEMO_MODE=false

# ── CORS Origins ───────────────────────────────────────────────
DEEPSYNAPS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ────────────────────────────────────────────────────
DEEPSYNAPS_LOG_LEVEL=INFO

# ── Redis (optional, future caching) ──────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Security (production only) ────────────────────────────────
# DEEPSYNAPS_JWT_SECRET=your-secret-key-here
# DEEPSYNAPS_ENCRYPTION_KEY=your-encryption-key-here
