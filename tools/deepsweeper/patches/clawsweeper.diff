 async function applyDecision(item: Item, decision: Decision, repo: TargetRepo) {
+  // Defense-in-depth: re-evaluate regulated check even if model said close.
+  const regulated = evaluateRegulated(
+    {
+      title: item.title,
+      body: item.body ?? "",
+      changedFiles: item.changedFiles ?? [],
+      commentTexts: (item.comments ?? []).map((c) => c.body ?? ""),
+    },
+    REGULATED_CONFIG,
+  );
+  decision = enforceRegulatedGuardrail(decision, regulated);
+
+  // Refuse close on regulated repos with applyClosures=false
+  if (!repo.applyClosures && decision.decision === "close") {
+    decision = { ...decision, decision: "keep_open", closeReason: "none", closeComment: "" };
+  }

   if (canClose(decision)) {
     // ... existing close logic ...
+    emitAuditRecord({
+      rootDir: ROOT,
+      actor: "deepsweeper-bot",
+      eventType: "deepsweeper.close",
+      payload: {
+        repo: `${repo.owner}/${repo.name}`,
+        item_number: item.number,
+        item_kind: item.kind,
+        close_reason: decision.closeReason,
+        confidence: decision.confidence,
+        regulated_check: regulated,
+        fixed_release: decision.fixedRelease,
+        fixed_sha: decision.fixedSha,
+        decision_sha: itemSnapshotHash(item, /* context */ {} as ItemContext),
+      },
+    });
+  } else {
+    emitAuditRecord({
+      rootDir: ROOT,
+      actor: "deepsweeper-bot",
+      eventType: "deepsweeper.keep_open",
+      payload: {
+        repo: `${repo.owner}/${repo.name}`,
+        item_number: item.number,
+        keep_open_reason: decision.keepOpenReason ?? "none",
+        regulated_check: regulated,
+      },
+    });
   }
 }

