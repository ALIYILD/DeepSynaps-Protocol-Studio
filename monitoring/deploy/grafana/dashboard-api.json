{
  "schemaVersion": 39,
  "title": "DeepSynaps API Performance",
  "description": "RED metrics dashboard for the DeepSynaps Protocol Studio API. Covers request rate, latency percentiles, error rates, and active connections. All queries are PHI-safe.",
  "tags": ["deepsynaps", "api", "red-method", "performance"],
  "timezone": "utc",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "query": "production,staging,development",
        "current": { "text": "production", "value": "production" },
        "multi": false,
        "includeAll": false
      },
      {
        "name": "endpoint_filter",
        "type": "textbox",
        "current": { "text": ".*", "value": ".*" },
        "label": "Endpoint regex"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": { "type": "prometheus", "uid": "${prometheus}" },
        "expr": "changes(deepsynaps_app_info{env=\"$environment\"}[1m]) > 0",
        "tagKeys": "version",
        "textFormat": "Deployed {{version}}",
        "iconColor": "blue"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (rps)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Requests per second by endpoint. Uses route templates to avoid cardinality explosion.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{env=\"$environment\",endpoint=~\"$endpoint_filter\"}[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Rate (total)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Total requests per second across all endpoints.",
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{env=\"$environment\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Percentage of requests returning 4xx/5xx status codes. SLO: < 0.1%.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{env=\"$environment\",status=~\"4xx|5xx\"}[5m])) / sum(rate(http_requests_total{env=\"$environment\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Uptime (99.9% SLO)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "API availability over the selected time range. Target: > 99.9%.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg_over_time(up{env=\"$environment\"}[$__range])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "P50 / P95 / P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Request latency percentiles across all endpoints. SLO: P95 < 200ms.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{env=\"$environment\",endpoint=~\"$endpoint_filter\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{env=\"$environment\",endpoint=~\"$endpoint_filter\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{env=\"$environment\",endpoint=~\"$endpoint_filter\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "SLO: P95 < 200ms",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Current P95 latency against the 200ms SLO.",
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "min": 0,
          "max": 0.5,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.15 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{env=\"$environment\"}[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active Connections",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Number of requests currently being processed. Fly.io hard limit: 25.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 30,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 18 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress{env=\"$environment\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Error Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Error rate per endpoint. Drill-down by clicking an endpoint to filter the row below.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{env=\"$environment\",status=~\"4xx|5xx\",endpoint=~\"$endpoint_filter\"}[5m])) by (endpoint) / sum(rate(http_requests_total{env=\"$environment\",endpoint=~\"$endpoint_filter\"}[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Status Code Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Distribution of HTTP status code families (2xx, 3xx, 4xx, 5xx).",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{env=\"$environment\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Top 10 Slowest Endpoints (P95)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Endpoints ranked by P95 latency over the last 5 minutes.",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "indexByName": { "Value": 2, "endpoint": 0, "method": 1 },
            "renameByName": { "Value": "P95 Latency (s)" }
          }
        }
      ],
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{env=\"$environment\"}[5m])) by (endpoint, method, le)))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Error Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Error rate classified by type: auth, validation, timeout, clinical, internal.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_errors_total{env=\"$environment\"}[5m])) by (error_type)",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Security Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Security-related events: failed auth, rate limit hits, privilege escalations.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(security_events_total{env=\"$environment\"}[5m])) by (event_type)",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Latency distribution over time. Darker cells = more requests in that latency bucket.",
      "dataFormat": "tsbuckets",
      "yAxis": { "format": "s", "logBase": 1, "max": 2 },
      "targets": [
        {
          "expr": "sum(increase(http_request_duration_seconds_bucket{env=\"$environment\",endpoint=~\"$endpoint_filter\"}[1m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    }
  ],
  "rows": [],
  "version": 1
}
