{
  "schemaVersion": 39,
  "title": "DeepSynaps Clinical Operations",
  "description": "Clinical operations dashboard for DeepSynaps Protocol Studio. Tracks protocols, assessments, patient data access, qEEG/MRI throughput, and clinical safety events. All metrics are PHI-safe — no patient identifiers.",
  "tags": ["deepsynaps", "clinical", "patient-safety", "operations"],
  "timezone": "utc",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "query": "production,staging,development",
        "current": { "text": "production", "value": "production" },
        "multi": false,
        "includeAll": false
      },
      {
        "name": "clinic",
        "type": "textbox",
        "current": { "text": ".*", "value": ".*" },
        "label": "Clinic filter (regex)"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Clinical Alerts",
        "datasource": { "type": "prometheus", "uid": "${prometheus}" },
        "expr": "increase(clinical_safety_events_total{env=\"$environment\"}[1m]) > 0",
        "tagKeys": "event",
        "textFormat": "Clinical safety event: {{event}}",
        "iconColor": "red"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Protocols Generated (per hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Protocol generation rate by actor role. Drill down by clicking a role series.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(clinical_operations_total{env=\"$environment\",operation=\"protocol_generate\"}[1h])) by (actor_role)",
          "legendFormat": "{{actor_role}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Protocols Generated (today)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Total protocols generated since midnight UTC.",
      "fieldConfig": {
        "defaults": { "unit": "none" }
      },
      "targets": [
        {
          "expr": "sum(increase(clinical_operations_total{env=\"$environment\",operation=\"protocol_generate\"}[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Treatment Sessions",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Number of currently active treatment sessions.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(active_sessions{env=\"$environment\",actor_role=\"patient\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Clinical Safety Status",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Clinical safety indicator. Green = no alerts firing.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "HEALTHY" } }, "type": "value" },
            { "options": { "1": { "text": "ALERT" } }, "type": "value" }
          ]
        }
      },
      "targets": [
        {
          "expr": "clamp_min(sum(ALERTS{env=\"$environment\",alertstate=\"firing\",alertgroup=\"clinical\"}), 0) or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Assessments Completed (per hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Assessment completion rate by type.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(clinical_operations_total{env=\"$environment\",operation=\"assessment_complete\"}[1h])) by (actor_role)",
          "legendFormat": "{{actor_role}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Assessment Completion Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Ratio of completed to started assessments in the last hour.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(clinical_operations_total{env=\"$environment\",operation=\"assessment_complete\"}[1h])) / sum(rate(clinical_operations_total{env=\"$environment\",operation=~\"assessment_complete|assessment_start\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Clinical Errors (1h rate)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Clinical endpoint error rate in the last hour.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_errors_total{env=\"$environment\",error_type=\"clinical\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Patient Data Access Patterns",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Patient data access events by operation type and actor role. Used for audit trend analysis.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(patient_data_access_total{env=\"$environment\"}[5m])) by (operation_type)",
          "legendFormat": "{{operation_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Patient Data Access by Role",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Distribution of patient data access by actor role.",
      "targets": [
        {
          "expr": "sum(rate(patient_data_access_total{env=\"$environment\"}[1h])) by (actor_role)",
          "legendFormat": "{{actor_role}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Anomalous Access Events",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Suspicious or anomalous patient data access events in the last hour.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(security_events_total{env=\"$environment\",event_type=\"suspicious_access\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Evidence Query Patterns",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Evidence database query rate by query type.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(evidence_queries_total{env=\"$environment\"}[5m])) by (query_type)",
          "legendFormat": "{{query_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Evidence DB Stale Data Alert",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Indicator for stale evidence database. Fires if no queries seen in 24h.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "STALE" } }, "type": "value" },
            { "options": { "1": { "text": "ACTIVE" } }, "type": "value" }
          ]
        }
      },
      "targets": [
        {
          "expr": "clamp_min(sum(rate(evidence_queries_total{env=\"$environment\"}[24h])), 0) or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "qEEG Analysis Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "qEEG analysis rate by analysis type and status.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(qeeg_analysis_duration_seconds_count{env=\"$environment\",status=\"success\"}[5m])) by (analysis_type)",
          "legendFormat": "{{analysis_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "qEEG Analysis P95 Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "P95 duration of qEEG analysis pipelines by type.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(qeeg_analysis_duration_seconds_bucket{env=\"$environment\",status=\"success\"}[5m])) by (analysis_type, le))",
          "legendFormat": "{{analysis_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "title": "MRI Analysis Throughput",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "MRI analysis jobs completed per hour.",
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "expr": "sum(increase(clinical_operations_total{env=\"$environment\",operation=\"mri_analysis\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "title": "Failed qEEG Analysis Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Rate of failed qEEG analyses. Alerts if > 5% failure rate.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.03 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(qeeg_analysis_duration_seconds_count{env=\"$environment\",status=\"error\"}[1h])) / sum(rate(qeeg_analysis_duration_seconds_count{env=\"$environment\"}[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "title": "Clinical Safety Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Clinical safety events over time: adverse events, assessment timeouts, protocol generation failures.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_errors_total{env=\"$environment\",error_type=\"clinical\"}[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(security_events_total{env=\"$environment\",severity=~\"high|critical\"}[5m]))",
          "legendFormat": "security_events",
          "refId": "B"
        }
      ]
    },
    {
      "id": 18,
      "title": "Adverse Events Reported",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Adverse events reported in the last 24 hours.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(clinical_operations_total{env=\"$environment\",operation=\"adverse_event_report\"}[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 19,
      "title": "Assessment Timeouts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Assessment timeout errors in the last 24 hours.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(http_errors_total{env=\"$environment\",error_type=\"timeout\"}[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "title": "Treatment Session Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "description": "Treatment session lifecycle events: start, complete, pause.",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(clinical_operations_total{env=\"$environment\",operation=~\"treatment_start|treatment_complete|treatment_pause\"}[5m])) by (operation)",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ]
    }
  ],
  "rows": [],
  "version": 1
}
