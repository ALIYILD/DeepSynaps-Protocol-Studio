{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deepsynaps.com/schemas/qeeg-payload/3.0.0",
  "title": "QEEGPayloadV3",
  "description": "Unified machine-readable contract for the qEEG pipeline payload. Folds the legacy CONTRACT.md (V1 — classical features, normative z-scores, quality, DB columns, AnalysisOut), CONTRACT_V2.md (V2 — AI upgrades: foundation embeddings, brain age, risk scores, GAMLSS centiles, explainability, similar cases, protocol recommendation, longitudinal, copilot), and CONTRACT_V3.md (V3 — multi-modal fusion, SSE progress, annotations, outcomes, FHIR/BIDS export, timeline, command palette, patient-facing view) into one spec. All AI/V2/V3 fields are optional and nullable; the V1 classical sub-tree (features/zscores/quality/flagged_conditions) remains the minimum required body that any caller must produce. The pipeline still treats the markdown files as source of truth — this schema is additive and used only by validators in PR-A.",
  "version": "v3",
  "type": "object",
  "required": [
    "features",
    "zscores",
    "flagged_conditions",
    "quality"
  ],
  "additionalProperties": true,

  "properties": {

    "features": {
      "$ref": "#/$defs/features",
      "description": "CONTRACT.md §1.1 + CONTRACT_V2.md §1 additions (embedding/brain_age/risk_scores/centiles/explainability)."
    },

    "zscores": {
      "$ref": "#/$defs/zscores",
      "description": "CONTRACT.md §1.2 — normative z-scores + flagged metric list + norm_db_version."
    },

    "flagged_conditions": {
      "type": "array",
      "description": "CONTRACT.md §1 — lowercase condition slugs (e.g. 'adhd', 'anxiety').",
      "items": { "type": "string" }
    },

    "quality": {
      "$ref": "#/$defs/quality",
      "description": "CONTRACT.md §1.3 — preprocessing / artifact-rejection quality metrics + pipeline_version + norm_db_version."
    },

    "report_html":     { "type": ["string", "null"] },
    "report_pdf_path": { "type": ["string", "null"] },

    "embeddings": {
      "type": ["object", "null"],
      "description": "Top-level dict of named foundation-model embeddings (e.g. labram-base, eegpt-base). Distinct from features.embedding which is the canonical 200-dim CONTRACT_V2 §1 array.",
      "additionalProperties": true
    },

    "similar_cases": {
      "type": ["array", "null"],
      "description": "CONTRACT_V2.md §1 — top-K nearest-neighbour analyses. List of opaque case dicts.",
      "items": { "type": "object", "additionalProperties": true }
    },

    "protocol_recommendation": {
      "anyOf": [
        { "$ref": "#/$defs/protocolRecommendation" },
        { "type": "null" }
      ],
      "description": "CONTRACT_V2.md §5 — single-modality ProtocolRecommendation."
    },

    "longitudinal": {
      "type": ["object", "null"],
      "description": "CONTRACT_V2.md §1 — per-feature trajectory summary across sessions.",
      "additionalProperties": true
    },

    "qc_flags": {
      "type": "array",
      "description": "Pipeline-level decision-support QC flags (mirrored from features.clinical_summary).",
      "items": { "type": "object", "additionalProperties": true }
    },

    "confidence": {
      "type": "object",
      "description": "Pipeline-level confidence metadata (mirrored from features.clinical_summary).",
      "additionalProperties": true
    },

    "method_provenance": {
      "type": "object",
      "description": "Pipeline-level provenance metadata (mirrored from features.clinical_summary).",
      "additionalProperties": true
    },

    "limitations": {
      "type": "array",
      "description": "Pipeline-level limitations list (mirrored from features.clinical_summary).",
      "items": { "type": "object", "additionalProperties": true }
    },

    "session_number":     { "type": ["integer", "null"] },
    "days_from_baseline": { "type": ["integer", "null"] },

    "analysis_out": {
      "$ref": "#/$defs/analysisOut",
      "description": "Optional sub-payload mirroring AnalysisOut as exposed by the API (CONTRACT.md §3 + CONTRACT_V2.md §3). Pipeline does not emit this directly; included so router-side test fixtures can validate against the same schema."
    },

    "ai_report": {
      "$ref": "#/$defs/aiReport",
      "description": "Optional embedded AI report (CONTRACT.md §5)."
    },

    "fusion_recommendation": {
      "anyOf": [
        { "$ref": "#/$defs/fusionRecommendation" },
        { "type": "null" }
      ],
      "description": "CONTRACT_V3.md §1 — multi-modal qEEG+MRI fusion output."
    },

    "annotations": {
      "type": "array",
      "description": "CONTRACT_V3.md §3 — clinician annotations attached to this analysis.",
      "items": { "$ref": "#/$defs/annotation" }
    },

    "outcomes": {
      "type": "array",
      "description": "CONTRACT_V3.md §4 — outcome events linked to recommendations from this analysis.",
      "items": { "$ref": "#/$defs/outcomeEvent" }
    },

    "patient_facing_summary": {
      "anyOf": [
        { "$ref": "#/$defs/patientFacingSummary" },
        { "type": "null" }
      ],
      "description": "CONTRACT_V3.md §9 — jargon-free patient-portal view."
    }

  },

  "$defs": {

    "channelMap": {
      "type": "object",
      "description": "Map of EEG channel name -> float (or nullable float). Channel names are 10-20 labels.",
      "additionalProperties": {
        "type": ["number", "null"]
      }
    },

    "matrix": {
      "type": "array",
      "description": "Square N_ch x N_ch numeric matrix.",
      "items": {
        "type": "array",
        "items": { "type": ["number", "null"] }
      }
    },

    "spectralBand": {
      "type": "object",
      "description": "Per-band spectral block (CONTRACT.md §1.1).",
      "additionalProperties": false,
      "properties": {
        "absolute_uv2": { "$ref": "#/$defs/channelMap" },
        "relative":     { "$ref": "#/$defs/channelMap" }
      }
    },

    "features": {
      "type": "object",
      "additionalProperties": true,
      "properties": {

        "spectral": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "bands": {
              "type": "object",
              "description": "Keyed by band name (delta, theta, alpha, beta, gamma).",
              "additionalProperties": { "$ref": "#/$defs/spectralBand" }
            },
            "aperiodic": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "slope":     { "$ref": "#/$defs/channelMap" },
                "offset":    { "$ref": "#/$defs/channelMap" },
                "r_squared": { "$ref": "#/$defs/channelMap" }
              }
            },
            "peak_alpha_freq": { "$ref": "#/$defs/channelMap" }
          }
        },

        "connectivity": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "wpli": {
              "type": "object",
              "description": "Per-band wPLI matrix.",
              "additionalProperties": { "$ref": "#/$defs/matrix" }
            },
            "coherence": {
              "type": "object",
              "description": "Per-band coherence matrix.",
              "additionalProperties": { "$ref": "#/$defs/matrix" }
            },
            "channels": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Row/col channel order for the matrices."
            }
          }
        },

        "asymmetry": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "frontal_alpha_F3_F4": { "type": ["number", "null"] },
            "frontal_alpha_F7_F8": { "type": ["number", "null"] }
          }
        },

        "graph": {
          "type": "object",
          "description": "Per-band graph metrics.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "clustering_coef":  { "type": ["number", "null"] },
              "char_path_length": { "type": ["number", "null"] },
              "small_worldness":  { "type": ["number", "null"] }
            }
          }
        },

        "source": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "roi_band_power": {
              "type": ["object", "null"],
              "description": "Per-band Desikan-Killiany ROI -> power.",
              "additionalProperties": { "$ref": "#/$defs/channelMap" }
            },
            "method": {
              "type": ["string", "null"],
              "description": "'eLORETA' | 'sLORETA' | null when source stage skipped."
            },
            "roi_table":    { "type": ["array", "null"] },
            "roi_csv_path": { "type": ["string", "null"] },
            "figures":      { "type": ["object", "null"] }
          }
        },

        "embedding": {
          "type": ["array", "null"],
          "description": "CONTRACT_V2.md §1 — 200-dim foundation-model embedding (e.g. LaBraM-Base).",
          "items": { "type": "number" }
        },

        "brain_age": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "predicted_years":      { "type": ["number", "null"] },
            "chronological_years":  { "type": ["integer", "null"] },
            "gap_years":            { "type": ["number", "null"] },
            "gap_percentile":       { "type": ["number", "null"] },
            "confidence":           { "type": ["string", "null"], "enum": ["low", "moderate", "high", null] },
            "electrode_importance": { "$ref": "#/$defs/channelMap" }
          }
        },

        "risk_scores": {
          "type": ["object", "null"],
          "description": "CONTRACT_V2.md §1 — similarity indices, NOT 'probability of disease'. Keyed by *_like risk name.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "score": { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 },
              "ci95":  {
                "type": "array",
                "items": { "type": ["number", "null"] },
                "minItems": 2,
                "maxItems": 2
              }
            }
          }
        },

        "centiles": {
          "type": ["object", "null"],
          "description": "CONTRACT_V2.md §1 — GAMLSS-derived centile tree alongside z-scores.",
          "additionalProperties": true,
          "properties": {
            "spectral":        { "type": ["object", "null"], "additionalProperties": true },
            "aperiodic":       { "type": ["object", "null"], "additionalProperties": true },
            "norm_db_version": { "type": ["string", "null"] }
          }
        },

        "explainability": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "per_risk_score": {
              "type": ["object", "null"],
              "additionalProperties": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "channel_importance": {
                    "type": ["object", "null"],
                    "additionalProperties": { "$ref": "#/$defs/channelMap" }
                  },
                  "top_channels": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": true,
                      "properties": {
                        "ch":    { "type": "string" },
                        "band":  { "type": "string" },
                        "score": { "type": "number" }
                      }
                    }
                  }
                }
              }
            },
            "ood_score": {
              "type": ["object", "null"],
              "additionalProperties": true,
              "properties": {
                "percentile":     { "type": ["number", "null"] },
                "distance":       { "type": ["number", "null"] },
                "interpretation": { "type": ["string", "null"] }
              }
            },
            "adebayo_sanity_pass": { "type": ["boolean", "null"] },
            "method": { "type": ["string", "null"] }
          }
        },

        "clinical_summary": {
          "type": ["object", "null"],
          "description": "Decision-support sub-tree feeding the top-level qc_flags / confidence / method_provenance / limitations mirror.",
          "additionalProperties": true
        }
      }
    },

    "zscores": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "spectral": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "bands": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/spectralBand" }
            }
          }
        },
        "aperiodic": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "slope": { "$ref": "#/$defs/channelMap" }
          }
        },
        "flagged": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["metric"],
            "properties": {
              "metric":  { "type": "string" },
              "channel": { "type": ["string", "null"] },
              "z":       { "type": ["number", "null"] }
            }
          }
        },
        "norm_db_version": { "type": ["string", "null"] }
      }
    },

    "quality": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "n_channels_input":    { "type": ["integer", "null"] },
        "n_channels_rejected": { "type": ["integer", "null"] },
        "bad_channels": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "n_epochs_total":    { "type": ["integer", "null"] },
        "n_epochs_retained": { "type": ["integer", "null"] },
        "ica_components_dropped": { "type": ["integer", "null"] },
        "ica_labels_dropped": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "integer" }
        },
        "sfreq_input":  { "type": ["number", "null"] },
        "sfreq_output": { "type": ["number", "null"] },
        "bandpass": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "notch_hz":         { "type": ["number", "null"] },
        "pipeline_version": { "type": ["string", "null"] },
        "norm_db_version":  { "type": ["string", "null"] },
        "stage_errors": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "string" }
        },
        "user_overrides_applied": { "type": ["boolean", "null"] },
        "recording_state":        { "type": ["string", "null"] },
        "medications": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        }
      }
    },

    "protocolRecommendation": {
      "type": "object",
      "description": "CONTRACT_V2.md §5.",
      "additionalProperties": true,
      "properties": {
        "primary_modality": { "type": ["string", "null"] },
        "target_region":    { "type": ["string", "null"] },
        "dose": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "sessions":     { "type": ["integer", "null"] },
            "intensity":    { "type": ["string", "null"] },
            "duration_min": { "type": ["integer", "null"] },
            "frequency":    { "type": ["string", "null"] }
          }
        },
        "session_plan": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "induction":     { "type": ["object", "null"], "additionalProperties": true },
            "consolidation": { "type": ["object", "null"], "additionalProperties": true },
            "maintenance":   { "type": ["object", "null"], "additionalProperties": true }
          }
        },
        "contraindications": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "expected_response_window_weeks": {
          "type": ["array", "null"],
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2
        },
        "citations": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/citation" }
        },
        "confidence": { "type": ["string", "null"], "enum": ["low", "moderate", "high", null] },
        "alternative_protocols": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/protocolRecommendation" }
        },
        "rationale": { "type": ["string", "null"], "maxLength": 1200 },
        "qeeg_support":     { "type": ["array", "null"], "items": { "$ref": "#/$defs/biomarkerSupport" } },
        "mri_support":      { "type": ["array", "null"], "items": { "$ref": "#/$defs/biomarkerSupport" } },
        "fusion_boost":     { "type": ["number", "null"] },
        "agreement_score":  { "type": ["number", "null"], "minimum": -1.0, "maximum": 1.0 },
        "conflicts": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "field":      { "type": "string" },
              "qeeg":       { "type": ["string", "null"] },
              "mri":        { "type": ["string", "null"] },
              "resolution": { "type": ["string", "null"] }
            }
          }
        }
      }
    },

    "biomarkerSupport": {
      "type": "object",
      "description": "CONTRACT_V3.md §1 — qEEG/MRI biomarker that contributed to a fusion target.",
      "additionalProperties": true,
      "properties": {
        "biomarker": { "type": "string" },
        "value":     { "type": ["number", "null"] },
        "z":         { "type": ["number", "null"] },
        "weight":    { "type": ["number", "null"] }
      }
    },

    "citation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "n":     { "type": ["integer", "null"] },
        "pmid":  { "type": ["string", "null"] },
        "doi":   { "type": ["string", "null"] },
        "title": { "type": ["string", "null"] },
        "year":  { "type": ["integer", "null"] },
        "url":   { "type": ["string", "null"] },
        "authors": { "type": ["string", "null"] },
        "journal": { "type": ["string", "null"] }
      }
    },

    "analysisOut": {
      "type": "object",
      "description": "AnalysisOut shape from CONTRACT.md §3 + CONTRACT_V2.md §3. All fields optional.",
      "additionalProperties": true,
      "properties": {
        "aperiodic":          { "type": ["object", "null"] },
        "peak_alpha_freq":    { "type": ["object", "null"] },
        "connectivity":       { "type": ["object", "null"] },
        "asymmetry":          { "type": ["object", "null"] },
        "graph_metrics":      { "type": ["object", "null"] },
        "source_roi":         { "type": ["object", "null"] },
        "normative_zscores":  { "type": ["object", "null"] },
        "flagged_conditions": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "quality_metrics":    { "type": ["object", "null"] },
        "pipeline_version":   { "type": ["string", "null"] },
        "norm_db_version":    { "type": ["string", "null"] },
        "embedding": {
          "type": ["array", "null"],
          "items": { "type": "number" }
        },
        "brain_age":               { "type": ["object", "null"] },
        "risk_scores":             { "type": ["object", "null"] },
        "centiles":                { "type": ["object", "null"] },
        "explainability":          { "type": ["object", "null"] },
        "similar_cases":           { "type": ["array", "null"] },
        "protocol_recommendation": { "type": ["object", "null"] },
        "longitudinal":            { "type": ["object", "null"] },
        "session_number":          { "type": ["integer", "null"] },
        "days_from_baseline":      { "type": ["integer", "null"] }
      }
    },

    "aiReport": {
      "type": "object",
      "description": "CONTRACT.md §5 — generate_ai_report output.",
      "additionalProperties": true,
      "properties": {
        "data": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "executive_summary": { "type": ["string", "null"], "maxLength": 1200 },
            "findings": {
              "type": ["array", "null"],
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "region":      { "type": ["string", "null"] },
                  "band":        { "type": ["string", "null"] },
                  "observation": { "type": ["string", "null"] },
                  "citations":   { "type": ["array", "null"], "items": { "type": "integer" } }
                }
              }
            },
            "protocol_recommendations": { "type": ["array", "null"] },
            "confidence_level": { "type": ["string", "null"], "enum": ["low", "moderate", "high", null] }
          }
        },
        "literature_refs": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/citation" }
        },
        "model_used":  { "type": ["string", "null"] },
        "prompt_hash": { "type": ["string", "null"] }
      }
    },

    "fusionRecommendation": {
      "type": "object",
      "description": "CONTRACT_V3.md §1.",
      "additionalProperties": true,
      "properties": {
        "patient_id":        { "type": "string" },
        "qeeg_analysis_id":  { "type": ["string", "null"] },
        "mri_analysis_id":   { "type": ["string", "null"] },
        "modalities_used":   {
          "type": "array",
          "items": { "type": "string", "enum": ["qeeg", "mri"] }
        },
        "generated_at":      { "type": "string" },
        "recommendations":   {
          "type": "array",
          "items": { "$ref": "#/$defs/protocolRecommendation" }
        },
        "summary":    { "type": ["string", "null"], "maxLength": 1200 },
        "disclaimer": { "type": ["string", "null"] }
      }
    },

    "annotation": {
      "type": "object",
      "description": "CONTRACT_V3.md §3 — clinician pin-to-finding.",
      "additionalProperties": true,
      "required": ["id", "analysis_id", "analysis_type", "author_id", "target", "text", "created_at"],
      "properties": {
        "id":            { "type": "string" },
        "analysis_id":   { "type": "string" },
        "analysis_type": { "type": "string", "enum": ["qeeg", "mri"] },
        "author_id":     { "type": "string" },
        "author_name":   { "type": ["string", "null"] },
        "target": {
          "type": "object",
          "additionalProperties": true,
          "required": ["kind", "ref"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["target", "zscore_cell", "roi", "finding", "section", "free"]
            },
            "ref": { "type": "string" }
          }
        },
        "text":        { "type": "string", "maxLength": 4000 },
        "created_at":  { "type": "string" },
        "updated_at":  { "type": ["string", "null"] },
        "resolved":    { "type": "boolean", "default": false },
        "resolved_by": { "type": ["string", "null"] },
        "tags":        { "type": "array", "items": { "type": "string" } }
      }
    },

    "outcomeEvent": {
      "type": "object",
      "description": "CONTRACT_V3.md §4.",
      "additionalProperties": true,
      "required": ["id", "patient_id", "source", "recommendation_id", "protocol_modality", "target_region", "accepted", "completed_sessions", "assessment_deltas", "adverse_events"],
      "properties": {
        "id":                { "type": "string" },
        "patient_id":        { "type": "string" },
        "source": {
          "type": "string",
          "enum": ["qeeg_recommendation", "mri_recommendation", "fusion_recommendation"]
        },
        "recommendation_id": { "type": "string" },
        "protocol_modality": { "type": "string" },
        "target_region":     { "type": "string" },
        "session_id":        { "type": ["string", "null"] },
        "accepted":          { "type": "boolean" },
        "started_at":        { "type": ["string", "null"] },
        "completed_sessions": { "type": "integer" },
        "assessment_deltas": { "type": "object", "additionalProperties": true },
        "adverse_events":    { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "adherence_pct":     { "type": ["number", "null"] },
        "notes":             { "type": ["string", "null"] }
      }
    },

    "patientFacingSummary": {
      "type": "object",
      "description": "CONTRACT_V3.md §9.",
      "additionalProperties": true,
      "required": ["analysis_id", "recorded_on", "findings_plain_language", "next_steps_generic", "regulatory_footer"],
      "properties": {
        "analysis_id":  { "type": "string" },
        "recorded_on":  { "type": "string" },
        "findings_plain_language": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["title", "body", "severity_hint"],
            "properties": {
              "title":         { "type": "string", "maxLength": 200 },
              "body":          { "type": "string", "maxLength": 200 },
              "severity_hint": { "type": "string", "enum": ["gentle", "moderate", "discuss_with_clinician"] }
            }
          }
        },
        "next_steps_generic": {
          "type": "array",
          "items": { "type": "string" }
        },
        "clinician_note_public": { "type": ["string", "null"] },
        "regulatory_footer":     { "type": "string" }
      }
    }

  }
}
