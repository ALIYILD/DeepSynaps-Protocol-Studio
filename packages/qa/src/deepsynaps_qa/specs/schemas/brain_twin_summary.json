{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deepsynaps.com/schemas/brain_twin_summary.json",
  "title": "Brain Twin Summary Card",
  "description": "Schema for Brain Twin summary card artifacts subject to QA scoring.",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "sections",
    "citations"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "const": "brain_twin_summary"
    },
    "content": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "subject_profile_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 hash of subject ID (never the raw ID)"
        }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["section_id"],
        "properties": {
          "section_id": { "type": "string" },
          "body": { "type": "string" }
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pmid": { "type": "string", "pattern": "^\\d{7,8}$" },
          "doi": { "type": "string" },
          "title": { "type": "string" }
        }
      }
    },
    "schema_ref": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
