# DeepSynaps Studio evidence pipeline — environment template.
# Copy to `.env` (gitignored) and fill in real values, or export in your shell profile.

# PubMed / NCBI E-utilities. Free, 2-min signup at
#   https://www.ncbi.nlm.nih.gov/account/settings/
# Bumps PubMed rate limit 3 → 10 req/s.
NCBI_API_KEY=

# Unpaywall. Email IS the key; no signup step.
UNPAYWALL_EMAIL=

# openFDA. Free key, instant at https://open.fda.gov/apis/authentication/
# (Endpoints also work without a key at a lower rate limit.)
OPENFDA_API_KEY=

# Crossref polite-pool identity. If omitted, UNPAYWALL_EMAIL is reused.
CROSSREF_MAILTO=

# Optional, now wired:
SEMANTIC_SCHOLAR_API_KEY=

# Still not wired:
# UMLS_API_KEY=                # SNOMED/ICD/MeSH mapping (NIH account, 1-2 days)

# Override DB location if you want it outside the repo:
# DEEPSYNAPS_DB=/absolute/path/to/evidence.db
